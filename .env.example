# Optional — Figma API token (also configurable in config.toml)
FIGMA_API_TOKEN=

# ---------------------------------------------------------------------------
# Compose merge — Docker-in-Docker sidecar (optional)
# ---------------------------------------------------------------------------
# Default: Takuto only (no container engine; strongest isolation).
# COMPOSE_FILE=docker-compose.yml
#
# Docker-in-Docker sidecar (works on all platforms — macOS Podman, Docker Desktop, Linux):
# COMPOSE_FILE=docker-compose.yml:docker-compose.dind.yml
#
# ⚠ podman-compose (Python) ignores COMPOSE_FILE in .env — use explicit -f flags:
#   podman compose -f docker-compose.yml -f docker-compose.dind.yml up -d
# docker compose (Go plugin) reads COMPOSE_FILE from .env as expected.
