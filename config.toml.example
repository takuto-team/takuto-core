[general]
dry_mode = false
poll_interval_secs = 60
max_concurrent_workflows = 1
max_fix_attempts = 3
log_level = "info"

[jira]
project_keys = ["PROJ"]
item_types = ["Task", "Bug"]
jql_filter = ""
# Required for token-based auth (leave empty to use OAuth during setup)
site = "yourcompany.atlassian.net"
email = "you@company.com"

[git]
base_branch = "main"
repo_url = "https://github.com/org/repo.git"
repo_path = "/workspace"

[commands]
# Command to run before install (e.g., registry auth: "aws codeartifact login ...")
# Shell commands run in order before install (e.g. registry auth). Use a TOML array; a single string is still accepted.
pre_install = []
install = "npm install"
lint = "npm run lint"
unit_test = "npm test"
e2e_test = "npm run test:e2e"

[web]
host = "0.0.0.0"
port = 8080

[claude]
skills_path = "/home/maestro/.claude/skills"
address_ticket_passes = 3
step_timeout_secs = 1800
figma_api_token = ""
# Model to use (e.g., "claude-opus-4-6", "claude-sonnet-4-6"). Empty = Claude Code default.
model = ""

[agent]
# AI tool for implement / review / fix steps: "claude" (Claude Code CLI) or "cursor" (Cursor Agent CLI).
provider = "claude"
# Executable for Cursor Agent (default: `agent` from https://cursor.com/install ). Only used when provider = "cursor".
cursor_cli = "agent"
# Cursor Agent --model. "Auto" (default) omits the flag so Cursor picks the model; set a concrete id to pin.
cursor_model = "Auto"

[docker]
# Shell commands (`bash -c`) run once during `docker compose build`, after tools are installed.
# Use for per-project setup such as installing Claude Code skills (replaces baked-in image install).
# The file used at build time is set by compose build arg MAESTRO_BUILD_CONFIG (default: config.toml.example).
# Example:
# build_commands run at image build time as root (see compose build arg MAESTRO_BUILD_CONFIG). Use for
# dependencies your compose_up_commands need (e.g. apt install rsync), not for layout that belongs in compose_up.
# build_commands = [
#   "apt-get update && apt-get install -y --no-install-recommends rsync",
# ]
build_commands = []

# compose_up_commands run on every `docker compose up` as the maestro user, after auth preflight, before the server.
# Avoid long multiline TOML hooks for root-only volume work (bash/sudo parsing issues). Cheat-sheet sync lives in
# the image as /usr/local/bin/maestro-sync-cheat-sheet-skills.sh and installs to /home/maestro/.claude/skills,
# /home/maestro/.cursor/skills, and /home/maestro/.cursor/skills-cursor — not /workspace/.cursor.
# compose_up_commands = [
#   "if ! sudo -n /usr/bin/bash -c 'true' 2>/dev/null; then echo 'rebuild image (sudoers for bash)' >&2; exit 1; fi; sudo -n /usr/bin/bash /usr/local/bin/maestro-sync-cheat-sheet-skills.sh",
# ]
compose_up_commands = []

[network]
# Additional domains to allow through the egress firewall
# (e.g., private npm registries, internal APIs)
extra_egress_hosts = []
# Example: extra_egress_hosts = ["mycompany.d.codeartifact.amazonaws.com", "internal-api.example.com"]
