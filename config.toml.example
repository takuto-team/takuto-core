# --- AI workflow (optional `[[agent_steps]]` at TOML root) ---
# Put `[[agent_steps]]` before `[general]` (or any `[table]`), or TOML binds them to the wrong section.
# Omit all `[[agent_steps]]`: built-in two-step sequence (implement + review), run once.
# With custom `[[agent_steps]]`: your list replaces the built-in steps entirely.
# Use each step's `repeat` (default 1) to run that step multiple times in a row.
#
# [[agent_steps]]
# name = "Implement ticket"
# prompt = """
# Implement {ticket_key}: {ticket_summary}
#
# {ticket_description}
#
# Acceptance criteria:
# {acceptance_criteria}
# """
# repeat = 1
#
# [[agent_steps]]
# name = "Review changes"
# prompt = "Review uncommitted changes for correctness and style. Fix issues."
# repeat = 1
#
# Placeholders: ticket_key, ticket_summary, ticket_description, ticket_type, acceptance_criteria, ticket_context
#
# --- PR review workflow (optional `[[review_agent_steps]]` at TOML root) ---
# Runs when the dashboard **Address PR Comments** action is used (main flow must be Done and a PR URL recorded).
# Same shape as `[[agent_steps]]` (`name`, `prompt`, `repeat`). Extra placeholder: **pr_url**.
# Omit all `[[review_agent_steps]]`: built-in single-step sequence once per **Address PR comments** run; use each step's `repeat` for multiple runs.
#
# [[review_agent_steps]]
# name = "Fix review comments"
# prompt = "PR: {pr_url}\n\n{ticket_context}\n\nResolve all unresolved GitHub review comments."
# repeat = 1
#
# --- Merge base branch workflow (optional `[[merge_base_agent_steps]]` at TOML root) ---
# Runs when the dashboard **Merge base branch** action is used (main flow must be Done, PR URL set, worktree present).
# Same shape as `[[agent_steps]]` / `[[review_agent_steps]]` (`name`, `prompt`, `repeat`).
# Placeholders: **pr_url**, **base_branch** (from `[git] base_branch`), plus ticket_key, ticket_summary,
# ticket_description, ticket_type, acceptance_criteria, ticket_context.
# Omit all `[[merge_base_agent_steps]]`: built-in single step that fetches/merges/tests/pushes against `{base_branch}`.
# The merge-base driver runs one outer pass over your step list; use each step's `repeat` to run a step multiple times
# in sequence (with `--resume` after the first run), same as custom `[[agent_steps]]`.

# [[merge_base_agent_steps]]
# name = "Merge base branch"
# prompt = """
# PR: {pr_url}
#
# Fetch `{base_branch}`, merge it into this branch, resolve conflicts, run tests, commit, and push.
#
# Ticket context:
# {ticket_context}
# """
# repeat = 1

[general]
dry_mode = false
# Start with Jira polling paused (same as dashboard **Pause polling**). Use **Resume polling** after startup to pick up To Do tickets without editing config again.
# pause_jira_polling_on_startup = true
poll_interval_secs = 60
# Concurrent install / agent sessions (semaphore across workflows).
max_concurrent_workflows = 1
# Max workflows still listed on the dashboard (every visible row, including **Done**, paused, stopped, error).
# Jira poller will not start new tickets while at this limit. Use **0** to mirror max_concurrent_workflows.
max_active_workflows = 0
# Dashboard **+** manual starts: max such workflows that are not **Done**, **Stopped**, or **Error** at once. **0** = no limit.
# max_concurrent_manual_workflows = 2
log_level = "info"
# Optional: load step lists from standalone TOML files (paths relative to this config file's directory).
# Copy **workflows/*.example.toml** → **workflows/ticket.toml** (etc.); real **workflows/*.toml** are gitignored.
# When set, inline [[agent_steps]] / [[review_agent_steps]] / [[merge_base_agent_steps]] in this file are ignored.
# ticket_workflow_steps_file = "workflows/ticket.toml"
# review_workflow_steps_file = "workflows/review.toml"
# merge_base_workflow_steps_file = "workflows/merge_base.toml"
# Docker image for isolated workflow containers. Default: auto-detected from this Maestro instance.
# worker_image = "maestro:latest"

[jira]
project_keys = ["PROJ"]
item_types = ["Task", "Bug"]
# Transition name for dashboard **Mark as Done** (must match your Jira workflow)
done_status = "Done"
# Optional: AND-merged into the dashboard **+** manual ticket picker JQL (e.g. board filter fragment) — Epics are always excluded there.
jql_filter = ""
# Host or https:// URL (token auth, egress, and Jira link in PR body; empty → jira.atlassian.net)
site = "yourcompany.atlassian.net"
email = "you@company.com"
# linked_items_in_prompt = "full"   # full | summary_only | omit — linked issue text in {ticket_context}
# ticket_context_max_description_bytes = 100000   # 0 = unlimited
# linked_issue_description_max_bytes = 32000    # 0 = unlimited (when mode is full)
# acli_allowed_extra_prefixes = []   # advanced: extra allowed acli argv prefix lines (tokens per line)

[git]
base_branch = "main"
# Git remote for fetch, worktree base ref, and push (default: origin)
remote = "origin"
repo_url = "https://github.com/org/repo.git"
repo_path = "/workspace"

[commands]
# Command to run before install (e.g., registry auth: "aws codeartifact login ...")
# Shell commands run in order before install (e.g. registry auth). Use a TOML array; a single string is still accepted.
pre_install = []
install = "npm install"
# Commands to run before each workflow starts (after worktree creation, before agent steps).
# pre_workflow = []

[web]
host = "0.0.0.0"
port = 8080
# Dashboard sign-in at /login.html when both are non-empty (HttpOnly session cookie). Leave "" to disable auth.
# GET /api/config never returns dashboard_password. Use strong unique values in production.
dashboard_username = ""
dashboard_password = ""

[agent]
# AI tool for implement / review / fix steps: "claude" (Claude Code CLI) or "cursor" (Cursor Agent CLI).
provider = "claude"
# Executable for Cursor Agent (default: `agent` from https://cursor.com/install ). Only used when provider = "cursor".
cursor_cli = "agent"
# Cursor Agent --model. "Auto" (default) uses automatic model selection; set a concrete id to pin.
cursor_model = "Auto"
# Timeout per agent session in seconds (applies to all providers).
step_timeout_secs = 1800
# Model override (e.g., "claude-opus-4-6", "claude-sonnet-4-6"). Empty = provider default.
model = ""

[docker]
# build_commands: optional `bash -c` steps during image build (see MAESTRO_BUILD_CONFIG in docker-compose).
# Claude/Cursor skills: use a gitignored ./skills folder at the Maestro repo root; merged on container start (README).
# build_commands = [
#   "apt-get update && apt-get install -y --no-install-recommends some-package",
# ]
build_commands = []

# compose_up_commands: optional; run as maestro after preflight. Skills from ./skills do not require a hook here.
compose_up_commands = []

[network]
# Additional domains to allow through the egress firewall
# (e.g., private npm registries, internal APIs)
extra_egress_hosts = []
# Example: extra_egress_hosts = ["mycompany.d.codeartifact.amazonaws.com", "internal-api.example.com"]
