# =============================================================================
# Takuto configuration
# =============================================================================
#
# This file has two kinds of settings:
#
#   • REQUIRED (bootstrap) — needed before the database and dashboard exist, or
#     applied only at startup. Hand-edit these before the first boot.
#
#   • OPTIONAL / UI-managed — have a sane default and are normally edited from
#     the dashboard's Configuration screens (the UI writes changes back here, so
#     this file stays the store). A value set here is just a deploy-time default;
#     keys editable in the UI are tagged `# Managed in Configuration → <tab>`.
#
# All workflow step definitions live in TOML files in the workflows/ directory.
# Copy workflows/*.example.toml → e.g. workflows/implement_ticket.toml
# (gitignored). Each definition file has top-level `name`, optional `depends_on`,
# and [[steps]] entries. See workflows/implement_ticket.example.toml.
#
# Worktree init commands and dashboard run/stop buttons are per-user and stored
# in the database — edit them via Configuration → Worktree Settings, not here.


# =============================================================================
# REQUIRED — bootstrap settings (hand-edit before first boot)
# =============================================================================

[general]
# Ticketing system that drives workflow automation.
# "none"   — no ticketing integration; start workflows manually from the dashboard (default).
# "jira"   — poll Jira for To Do tickets; requires Atlassian CLI (acli) auth (run make setup).
# "github" — poll GitHub Issues from the git remote; no Atlassian auth required.
ticketing_system = "none"
# Logging verbosity: trace | debug | info | warn | error. Startup/restart only.
log_level = "info"
# Docker image for isolated workflow containers. Default: auto-detected from this Takuto instance.
# worker_image = "takuto:latest"
# Path scanned for *.toml workflow definitions, resolved relative to this file. Startup/restart only.
# workflow_definitions_dir = "workflows"
# When true (default), the server auto-generates {data_dir}/secret.key on first
# boot if neither TAKUTO_SECRET_KEY nor an existing keyfile is present. Set to
# false in hardened environments where the key is provisioned out of band.
# allow_auto_generate_secret_key = true
# Skip real Jira/GitHub side effects (no assigns, transitions, or pushes); local
# work still runs. Deploy-time only (also available as CLI --dry-run).
# dry_mode = false
# When true, snapshot workflows with no owner (pre-multi-user orphans) are
# reassigned to the resolved poller owner at startup. Default false.
# migrate_orphan_workflows = false
# When true (default), startup reconciliation re-associates restored workflows
# with their owner's registered repository. Set false to require manual re-add.
# migrate_orphan_repo_associations = true

# --- UI-managed [general] keys (deploy-time defaults; edit in the UI) ---
# Enable/disable polling and the poll cadence.
# Managed in Configuration → Item Polling.
# auto_polling = true
poll_interval_secs = 60
# Interval (seconds) for polling GitHub to check whether workflow PRs have been merged. 0 disables.
# Managed in Configuration → Item Polling.
pr_merge_poll_interval_secs = 60
# Concurrent install / agent sessions (semaphore across workflows).
# Managed in Configuration → Item Polling.
max_concurrent_workflows = 1
# Max workflows still listed on the dashboard (every visible row, including **Done**, paused, stopped, error).
# Jira poller will not start new tickets while at this limit. Use **0** to mirror max_concurrent_workflows.
# Managed in Configuration → Item Polling.
max_active_workflows = 0
# Dashboard **+** manual starts: max such workflows that are not **Done**, **Stopped**, or **Error** at once. **0** = no limit.
# Managed in Configuration → Item Polling.
# max_concurrent_manual_workflows = 2
# When true, each agent step appends findings to lore/reports/<item-key>_report.md
# and a final consolidation step produces a polished summary. Default false.
# Managed in Configuration → Item Polling.
# generate_report = false
# Days of work-item log lines to retain before cleanup. 0 = keep forever. Default 7.
# Managed in Configuration → Item Polling.
# work_item_log_retention_days = 7
# Username of the user who owns workflows created automatically by the Jira/GitHub poller.
# When unset, the lexicographically-first non-suspended admin is used. When set but the
# named user is missing or suspended, a warning is logged and the admin fallback applies.
# When neither resolves, polling-created workflows are skipped entirely.
# poller_owner_username = "alice"

[git]
base_branch = "main"
# Git remote for fetch, worktree base ref, and push (default: origin)
remote = "origin"
repo_path = "/workspace"

[web]
host = "0.0.0.0"
port = 8080
# Allowed CORS origins. When empty (default), auto-computed from host and port
# (e.g. http://localhost:8080 when host is 0.0.0.0).
# Set explicitly when behind a reverse proxy or TLS terminator:
#   cors_origins = ["https://takuto.example.com"]
# Multiple origins are supported (e.g. for dev + production access):
#   cors_origins = ["http://localhost:8080", "https://takuto.example.com"]
# Startup-only — not changeable via PUT /api/config. Requires restart.
cors_origins = []
# Controls the `Secure` flag on the session cookie. When unset (default),
# Takuto auto-detects: the flag is set when any `cors_origins` entry is
# `https://…` OR when the inbound request carries `X-Forwarded-Proto: https`
# (so a TLS-terminating reverse proxy is enough). Set explicitly to `true`
# to force the flag on (e.g. when terminating TLS in front of Takuto without
# advertising `X-Forwarded-Proto`), or to `false` for local plain-HTTP testing.
# cookie_secure = true
# Whether a successful login deletes all prior sessions for the same user.
# Default `true` — security-first single-session enforcement. Set to `false`
# if you want long-lived multi-client sessions (e.g. desktop + mobile).
# Note: idle session TTL is 24 h, absolute TTL is 30 days regardless of this
# setting. After 5 failed login or recovery attempts in 10 min the account
# is temporarily locked (admin can clear via POST /api/users/{id}/unlock).
# Per-IP rate limit on /api/auth/login and /api/auth/recover is 10 / min.
# kick_other_sessions_on_login = true

[jira]
# Host or https:// URL (token auth, egress, and Jira link in PR body; empty → jira.atlassian.net)
site = "yourcompany.atlassian.net"
email = "you@company.com"
# --- UI-managed [jira] keys (deploy-time defaults; edit in the UI) ---
# Managed in Configuration → Item Polling.
project_keys = ["PROJ"]
item_types = ["Task", "Bug"]
# Transition name for dashboard **Mark as Done** (must match your Jira workflow)
done_status = "Done"
# Optional: AND-merged into the dashboard **+** manual ticket picker JQL (e.g. board filter fragment) — Epics are always excluded there.
jql_filter = ""
# linked_items_in_prompt = "full"   # full | summary_only | omit — linked issue text in {ticket_context}
# ticket_context_max_description_bytes = 100000   # 0 = unlimited
# linked_issue_description_max_bytes = 32000    # 0 = unlimited (when mode is full)
# acli_allowed_extra_prefixes = []   # advanced: extra allowed acli argv prefix lines (tokens per line)

# --- GitHub App authentication (optional) ---
# When configured, Takuto authenticates as a GitHub App bot identity instead
# of the personal `gh` user. Commits and PRs will be attributed to
# `takuto-bot[bot]` (visible in the GitHub UI).
#
# All three fields (app_id, app_installation_id, and one private key source)
# must be set to enable GitHub App authentication. Errors in the private key
# or installation ID are non-fatal at startup — Takuto falls back to personal
# `gh` auth and logs a warning.
#
# Required App permissions: contents (write), pull_requests (write), metadata (read).
#
# [github]
# app_id = 123456
# app_installation_id = 78901234
# # PEM-encoded RSA private key (inline). Set either this or app_private_key_path.
# app_private_key = """
# -----BEGIN RSA PRIVATE KEY-----
# MIIEpAIBAAKCAQEA...
# -----END RSA PRIVATE KEY-----
# """
# # Or: path to a PEM file (alternative to inline key).
# # app_private_key_path = "/etc/takuto/github-app-key.pem"
#
# --- gh CLI allowlist (advanced) ---
# Extra `gh` argv prefixes allowed beyond Takuto's built-in set.
# Built-in: api, pr create, pr edit, auth login, auth setup-git, auth status.
# Each entry is a whitespace-separated token line (e.g. "pr list").
# Set to ["*"] to allow ALL gh subcommands (disables the gh allowlist entirely).
# gh_allowed_extra_prefixes = []

# --- External database backend ---
#
# By default, Takuto stores users, sessions, credentials, and audit data in a
# local SQLite file at {data_dir}/takuto.db. For multi-instance deployments
# (or operators who want to centralise auth state in their existing DB), the
# [database] block points Takuto at PostgreSQL, MySQL, or MariaDB.
#
# Leaving the section out (or `connection = ""`) keeps the current SQLite
# behaviour — zero-config default.
#
# Restart-only: `PUT /api/config` will not patch this section. Backend changes
# require a process restart, same policy as `web.host` / `web.port`.
#
# [database]
# # Connection URL. Empty / omitted → SQLite at {data_dir}/takuto.db.
# # Supported schemes:
# #   sqlite://path/to/file.db
# #   postgres://user:pw@host:5432/db
# #   postgresql://user:pw@host:5432/db   (alias)
# #   mysql://user:pw@host:3306/db        (covers MariaDB)
# # `GET /api/config` redacts the password component before returning.
# connection = "postgres://takuto:s3cret@db.example:5432/takuto"
#
# # Pool tuning (all optional). Defaults: 10 conns, 30 s acquire timeout,
# # 10 min idle timeout.
# # max_connections = 10
# # acquire_timeout_secs = 30
# # idle_timeout_secs = 600
#
# # When true (default), startup runs a 5 s `SELECT 1` probe against the
# # configured backend and aborts if the database is unreachable. When false,
# # an unreachable backend logs a warning and falls back to local SQLite for
# # the current process (recovery path).
# # fail_fast = true
#
# # When true (default) and a legacy {data_dir}/takuto.db exists AND the
# # remote target has no `system_metadata.import_complete` row, perform a
# # one-shot copy of every user-data table inside a single transaction at
# # startup. Sessions are marked expired post-import so users re-authenticate.
# # Subsequent restarts skip the import (the marker row is the gate). Operators
# # who want to redo the import can `DELETE FROM system_metadata WHERE key =
# # 'import_complete'` against the target — there is no CLI for it on purpose.
# # import_from_sqlite = true


# =============================================================================
# OPTIONAL / UI-managed — seed a deploy-time default; normally edited in the UI
# =============================================================================

[agent]
# All [agent] keys are editable from Configuration → AI Settings.
# AI tool for implement / review / fix steps: "claude", "cursor", "codex", or "opencode".
provider = "claude"
# Timeout per agent session in seconds (applies to all providers).
step_timeout_secs = 1800
# Share one agent conversation across all steps in a flow. When true, each step
# resumes the previous step's session (the agent remembers what it implemented
# when it reviews). When false (default), every step runs in a fresh session —
# safer for smaller local models that get confused by long shared transcripts.
share_conversation_across_steps = false
# No-progress guardrail: abort an agent step when its output repeats the same
# substantive line this many times in a row — the signature of a weak model
# looping on a failing action (e.g. a `git push` it can't fix). The step fails
# into Error instead of churning until step_timeout_secs. Session-lifecycle
# lines ("… initialized/completed") are excluded so healthy multi-turn runs
# aren't tripped. 0 disables. Default 8.
max_repeated_output_lines = 8

# Per-provider sub-tables. Each provider keeps its own model / endpoint / args.
# Managed in Configuration → AI Settings.
# [agent.providers.cursor]
# cli = "agent"          # Cursor Agent executable (from https://cursor.com/install)
# model = "Auto"         # "Auto" = automatic model selection; or pin a concrete id

# OpenCode (self-hosted, OpenAI-compatible endpoints like LM Studio / Ollama /
# vLLM). Only used when provider = "opencode".
# [agent.providers.opencode]
# # Model id served by your endpoint (the `<model>` in `-m self_hosted/<model>`).
# model = "qwen2.5-coder-7b-instruct"
# # OpenAI-compatible base URL of the model server (required).
# base_url = "http://lm-studio:1234/v1"
# # Token limits for the self-hosted model. OpenCode can't look these up for a
# # local endpoint, so set them to match your server's loaded context length;
# # this lets OpenCode track remaining context. Default to a 7B-class coder
# # window (context 32768 / output 8192) when omitted — override to match your
# # model, or set to clear from the dashboard to let OpenCode guess.
# context_limit = 32768
# output_limit = 8192

# --- Item polling policy ---
# Shapes what the Jira/GitHub pollers auto-add, which flow they auto-start, and
# how many items run in parallel. Read live by the pollers each cycle (no restart).
# Managed in Configuration → Item Polling (PUT /api/config/polling).
[polling]
# Slug of the single flow to auto-start for each polled item.
# Empty (default) = start ALL dependency-free flows (legacy behavior).
# A slug that does not match any dependency-free flow logs a warning and starts
# nothing (the item is still added to the dashboard so you notice).
auto_start_flow = ""
# Cap on items occupying a concurrency slot at once. 0 = unlimited.
# The poller takes the tighter of this and the legacy max_active_workflows;
# manual starts enforce it as an independent 409 ceiling (alongside
# max_concurrent_manual_workflows).
max_parallel_items = 0
# When true, max_parallel_items is counted per workflow owner; false = global.
max_parallel_per_user = false

# Jira poller filter. Empty list = no filter. Jira item TYPES are configured
# under [jira] item_types (not duplicated here).
[polling.jira]
# Case-insensitive ANY-substring match against the ticket summary.
# Blank/whitespace-only entries are rejected at save time.
summary_keywords = []

# GitHub poller filter. Empty list = no filter.
[polling.github]
# Exact label membership, ANY match (issue kept if it carries any listed label).
labels = []
# Case-insensitive ANY-substring match against the issue title.
title_keywords = []


# =============================================================================
# ADVANCED HOOKS — bootstrap / deploy-time (most deployments leave defaults)
# =============================================================================

[docker]
# build_commands: optional `bash -c` steps during image build (see TAKUTO_BUILD_CONFIG in docker-compose).
# Claude/Cursor skills: use a gitignored ./skills folder at the Takuto repo root; merged on container start (README).
# build_commands = [
#   "apt-get update && apt-get install -y --no-install-recommends some-package",
# ]
build_commands = []

# compose_up_commands: optional; run as takuto after preflight. Skills from ./skills do not require a hook here.
compose_up_commands = []

[editor]
# Application ports to expose when opening VS Code editor from the dashboard
# (e.g. dev server, Storybook). Each port in the container is mapped to a host
# port from the DinD range (9100-9200); mappings are shown on the workflow card.
# ports = [3000, 5173, 6006]

# Number of extra spare ports pre-allocated for automatic detection and forwarding
# of dev servers started inside the editor (e.g. Storybook on port 6006). When a new
# listening port is detected, socat forwards traffic from a spare host port to the
# container port. A toast notification appears on the dashboard with the forwarded URL.
# Set to 0 to disable dynamic port forwarding. Default: 10.
# dynamic_ports = 10

# VS Code color theme
# theme = "One Dark Pro"

# Extensions to pre-install (marketplace IDs)
# extensions = [
#   "esbenp.prettier-vscode",
#   "dbaeumer.vscode-eslint",
#   "eamodio.gitlens",
#   "bradlc.vscode-tailwindcss",
#   "ms-python.python",
# ]

# VS Code settings (any valid setting key = value)
# [editor.settings]
# "editor.fontSize" = 14
# "editor.tabSize" = 2
# "editor.formatOnSave" = true
# "editor.minimap.enabled" = false
# "editor.wordWrap" = "on"
# "terminal.integrated.fontSize" = 13
# "files.autoSave" = "afterDelay"
# "editor.bracketPairColorization.enabled" = true

[terminal]
# Default git editor installed and configured inside every editor container.
# Must be an apt package name (e.g. "nano", "vim", "micro", "helix").
# When set, the package is installed via apt and `git config --global core.editor`
# is updated for the takuto user so git commands (commit, rebase -i, etc.) open
# the chosen editor instead of failing with "unable to start editor 'editor'".
# git_editor = "nano"

# Shell commands run ONCE per editor container lifetime (guarded by a marker file).
# Use for expensive one-time setup: apt packages, tool configuration, etc.
# `/etc/takuto/env` is sourced before each command (API tokens available).
# Mise installs persist in the shared mise volume across container restarts.
# setup_commands = [
#   "mise use -g zellij@latest neovim@latest",
# ]

# Shell commands run EVERY TIME a fresh editor container is created (no once-only guard).
# Use for tools that should be verified/updated on each editor open, e.g. language
# runtimes managed by mise. The shared mise volume caches installs, so only the first
# run downloads; subsequent runs just verify the version is current (fast).
# Note: Rust (cargo, rustc, rustfmt, clippy) is pre-installed in the image — no need
# to add it here.
# startup_commands = [
#   "mise use -g java@21",
#   "mise use -g ruby@3.3",
#   "mise use -g golang@latest",
# ]

[network]
# Additional domains to allow through the egress firewall
# (e.g., private npm registries, internal APIs)
extra_egress_hosts = []
# Example: extra_egress_hosts = ["mycompany.d.codeartifact.amazonaws.com", "internal-api.example.com"]
# When true, skip the egress allowlist and permit all outbound HTTPS (ports 443/8443).
# Use only in trusted environments; `extra_egress_hosts` is ignored when this is enabled.
# allow_all_https = false

# ─── [provisioning] — admin-installed tools ─────────────────────────────
#
# Shell commands that install tools into the shared `takuto-tools`
# Docker volume on takuto startup. The volume is bind-mounted READ-ONLY
# into every container Takuto spawns (workers, editors, run-commands)
# at `/opt/takuto-tools/bin`, and the takuto image prepends that path
# to `$PATH` — so anything installed here is on PATH everywhere AND can
# OVERRIDE a baked tool by name (PATH precedence).
#
# Behavior:
#   • SHA-gated: takuto hashes the (canonicalized) `install_commands`
#     list. If the SHA matches the recorded one in
#     `/opt/takuto-tools/.provisioning-sha`, the install pass is SKIPPED.
#     Edit this list → SHA changes → installs run again.
#   • Each command runs as ROOT via `bash -c "$cmd"`. To run as the
#     takuto user (e.g. `mise install`), wrap with `runuser -u takuto --`.
#   • `$TAKUTO_TOOLS_BIN` expands to `/opt/takuto-tools/bin`.
#   • Per-command failures log a WARNING but do NOT abort takuto boot.
#     The SHA is only recorded on FULL success — partial-failure boots
#     retry on the next restart.
#
# Decision guide (when do I use this vs a custom image?):
#   • Single binary CLI tool (kubectl, terraform, a vendor CLI) → here.
#   • Pin a baked tool to a specific version → here (PATH shadowing).
#   • System packages (apt, libraries) → custom Dockerfile `FROM takuto:latest`.
#   • Extra env vars / mounts → docker-compose.override.yml.
# See `docs/extending-takuto.md` for the full reference.
#
# Force re-install (admin escape hatch):
#   docker exec --user root takuto-core-takuto-1 \
#     rm /opt/takuto-tools/.provisioning-sha && docker compose restart takuto
#
# Wipe all customizations and start fresh:
#   docker volume rm takuto-core_takuto-tools && docker compose up -d
[provisioning]
install_commands = [
  # fcli (Figma CLI). Migrated out of the baked image so admins can pin
  # the version or skip the install. amd64 prebuilt; other arches skipped.
  '[ -f "$TAKUTO_TOOLS_BIN/fcli" ] || (ARCH=$(dpkg --print-architecture); [ "$ARCH" = "amd64" ] && curl -fsSL https://github.com/morphet81/figma-cli/releases/download/v0.2.0/fcli-v0.2.0-x86_64-unknown-linux-gnu.tar.gz -o /tmp/fcli.tar.gz && tar -xzf /tmp/fcli.tar.gz -C /tmp && install -m 0755 /tmp/fcli "$TAKUTO_TOOLS_BIN/fcli" && rm -rf /tmp/fcli /tmp/fcli.tar.gz || echo "WARN: fcli skipped on $ARCH")',

  # lokalise2 (Lokalise CLI v2). Single Go binary.
  '[ -f "$TAKUTO_TOOLS_BIN/lokalise2" ] || (ARCH=$(dpkg --print-architecture); case "$ARCH" in amd64) LA=x86_64;; arm64) LA=arm64;; *) LA="";; esac; [ -n "$LA" ] && curl -fSL https://github.com/lokalise/lokalise-cli-2-go/releases/latest/download/lokalise2_linux_${LA}.tar.gz -o /tmp/lk.tar.gz && tar -xzf /tmp/lk.tar.gz -C /tmp && install -m 0755 /tmp/lokalise2 "$TAKUTO_TOOLS_BIN/lokalise2" && rm -rf /tmp/lokalise2 /tmp/lk.tar.gz || echo "WARN: lokalise2 skipped on $ARCH")',

  # figma-cli (npm-based). Installed into the tools volume so workers
  # see it without a global npm prefix override.
  '[ -f "$TAKUTO_TOOLS_BIN/figma-cli" ] || (npm install -g --prefix "$TAKUTO_TOOLS_BIN/.npm" figma-cli && ln -sf "$TAKUTO_TOOLS_BIN/.npm/bin/figma-cli" "$TAKUTO_TOOLS_BIN/figma-cli")',

  # ─── Examples (uncomment to enable) ────────────────────────────────
  #
  # Pin claude to a specific version (overrides the baked @latest):
  #   '[ -f "$TAKUTO_TOOLS_BIN/claude" ] || (npm install -g --prefix "$TAKUTO_TOOLS_BIN/.npm" @anthropic-ai/claude-code@2.1.140 && ln -sf "$TAKUTO_TOOLS_BIN/.npm/bin/claude" "$TAKUTO_TOOLS_BIN/claude")',
  #
  # Install kubectl for workflows that hit a Kubernetes cluster:
  #   '[ -f "$TAKUTO_TOOLS_BIN/kubectl" ] || (curl -fsSLo "$TAKUTO_TOOLS_BIN/kubectl" https://dl.k8s.io/release/v1.31.0/bin/linux/amd64/kubectl && chmod +x "$TAKUTO_TOOLS_BIN/kubectl")',
  #
  # Install AWS CLI v2 (removed from the bake — admin opts in here):
  #   '[ -f "$TAKUTO_TOOLS_BIN/aws" ] || (curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o /tmp/aws.zip && unzip -q /tmp/aws.zip -d /tmp && /tmp/aws/install --bin-dir "$TAKUTO_TOOLS_BIN" --install-dir "$TAKUTO_TOOLS_BIN/aws-cli" --update && rm -rf /tmp/aws*)',
]

# --- Dev-only knobs (leave commented in production) ---
# When `mock_agent = true`, ClaudeSession::run_prompt and CursorSession::run_prompt
# short-circuit into a scripted mock session — no real `claude` or `agent` process
# is spawned, no API tokens are consumed. Designed for E2E tests and dashboard demos.
# Honors the env var override `TAKUTO_DEV_MOCK_AGENT=1` (env wins over config).
# [dev]
# mock_agent = false
# mock_agent_script_path = "tmp/mock_script.txt"
# mock_agent_line_delay_ms = 75
# mock_agent_total_ms = 5000
