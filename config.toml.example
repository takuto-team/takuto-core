# --- Workflow definitions ---
# All workflow step definitions live in TOML files in the workflows/ directory.
# Copy workflows/*.example.toml → e.g. workflows/implement_ticket.toml (gitignored).
# Each definition file has top-level `name`, optional `depends_on`, and [[steps]] entries.
# See workflows/implement_ticket.example.toml for the full format.

# Worktree init commands and run commands are now per-user, configured
# via the dashboard's Configuration → Worktree Settings tab. Any stale
# `[commands]` or `[[run_commands]]` entries in this file are ignored at
# load time (a startup warning is logged so you notice).

[general]
dry_mode = false
# Ticketing system that drives workflow automation.
# "none"   — no ticketing integration; start workflows manually from the dashboard (default).
# "jira"   — poll Jira for To Do tickets; requires Atlassian CLI (acli) auth (run make setup).
# "github" — poll GitHub Issues from the git remote; no Atlassian auth required.
ticketing_system = "none"
# Set to false to start with Jira polling paused (same as dashboard **Pause polling**). Use **Resume polling** after startup to pick up To Do tickets without editing config again.
# auto_polling = false
poll_interval_secs = 60
# Interval (seconds) for polling GitHub to check whether workflow PRs have been merged. 0 disables.
pr_merge_poll_interval_secs = 60
# Concurrent install / agent sessions (semaphore across workflows).
max_concurrent_workflows = 1
# Max workflows still listed on the dashboard (every visible row, including **Done**, paused, stopped, error).
# Jira poller will not start new tickets while at this limit. Use **0** to mirror max_concurrent_workflows.
max_active_workflows = 0
# Dashboard **+** manual starts: max such workflows that are not **Done**, **Stopped**, or **Error** at once. **0** = no limit.
# max_concurrent_manual_workflows = 2
# When true, each agent step appends findings to lore/reports/<item-key>_report.md
# and a final consolidation step produces a polished summary. The Report button
# on the dashboard shows the result. Default: false (no report overhead).
# generate_report = false
# Username of the user who owns workflows created automatically by the Jira/GitHub poller.
# When unset, the lexicographically-first non-suspended admin is used. When set but the
# named user is missing or suspended, a warning is logged and the admin fallback applies.
# When neither resolves, polling-created workflows are skipped entirely.
# poller_owner_username = "alice"
# When true, workflows restored from snapshot with no owner (e.g. pre-multi-user orphans)
# are reassigned to the resolved poller owner at startup so they appear on that user's
# dashboard. Default false — orphans remain invisible until an explicit migration.
# migrate_orphan_workflows = false
# Plan-10: when true (default), startup reconciliation creates a `user_repositories`
# association for every restored snapshot workflow that has a `user_id` and whose
# `workspace_name` matches a registered repository — so workflows that pre-date
# plan-10's per-user repo model stay visible on their owner's dashboard. Set to
# false to require each user to explicitly re-add the repository from the
# dashboard's My Repositories tab before their old workflows reappear.
# migrate_orphan_repo_associations = true
log_level = "info"
# Docker image for isolated workflow containers. Default: auto-detected from this Maestro instance.
# worker_image = "maestro:latest"

[jira]
project_keys = ["PROJ"]
item_types = ["Task", "Bug"]
# Transition name for dashboard **Mark as Done** (must match your Jira workflow)
done_status = "Done"
# Optional: AND-merged into the dashboard **+** manual ticket picker JQL (e.g. board filter fragment) — Epics are always excluded there.
jql_filter = ""
# Host or https:// URL (token auth, egress, and Jira link in PR body; empty → jira.atlassian.net)
site = "yourcompany.atlassian.net"
email = "you@company.com"
# linked_items_in_prompt = "full"   # full | summary_only | omit — linked issue text in {ticket_context}
# ticket_context_max_description_bytes = 100000   # 0 = unlimited
# linked_issue_description_max_bytes = 32000    # 0 = unlimited (when mode is full)
# acli_allowed_extra_prefixes = []   # advanced: extra allowed acli argv prefix lines (tokens per line)

[git]
base_branch = "main"
# Git remote for fetch, worktree base ref, and push (default: origin)
remote = "origin"
repo_path = "/workspace"

# --- GitHub App authentication (optional) ---
# When configured, Maestro authenticates as a GitHub App bot identity instead
# of the personal `gh` user. Commits and PRs will be attributed to
# `maestro-bot[bot]` (visible in the GitHub UI).
#
# All three fields (app_id, app_installation_id, and one private key source)
# must be set to enable GitHub App authentication. Errors in the private key
# or installation ID are non-fatal at startup — Maestro falls back to personal
# `gh` auth and logs a warning.
#
# Required App permissions: contents (write), pull_requests (write), metadata (read).
#
# [github]
# app_id = 123456
# app_installation_id = 78901234
# # PEM-encoded RSA private key (inline). Set either this or app_private_key_path.
# app_private_key = """
# -----BEGIN RSA PRIVATE KEY-----
# MIIEpAIBAAKCAQEA...
# -----END RSA PRIVATE KEY-----
# """
# # Or: path to a PEM file (alternative to inline key).
# # app_private_key_path = "/etc/maestro/github-app-key.pem"
#
# --- gh CLI allowlist (advanced) ---
# Extra `gh` argv prefixes allowed beyond Maestro's built-in set.
# Built-in: api, pr create, pr edit, auth login, auth setup-git, auth status.
# Each entry is a whitespace-separated token line (e.g. "pr list").
# Set to ["*"] to allow ALL gh subcommands (disables the gh allowlist entirely).
# gh_allowed_extra_prefixes = []

[web]
host = "0.0.0.0"
port = 8080
# Dashboard sign-in at /login.html when both are non-empty (HttpOnly session cookie). Leave "" to disable auth.
# GET /api/config never returns dashboard_password. Use strong unique values in production.
dashboard_username = ""
dashboard_password = ""
# Allowed CORS origins. When empty (default), auto-computed from host and port
# (e.g. http://localhost:8080 when host is 0.0.0.0).
# Set explicitly when behind a reverse proxy or TLS terminator:
#   cors_origins = ["https://maestro.example.com"]
# Multiple origins are supported (e.g. for dev + production access):
#   cors_origins = ["http://localhost:8080", "https://maestro.example.com"]
# Startup-only — not changeable via PUT /api/config. Requires restart.
cors_origins = []
# Controls the `Secure` flag on the session cookie. When unset (default),
# Maestro auto-detects: the flag is set when any `cors_origins` entry is
# `https://…` OR when the inbound request carries `X-Forwarded-Proto: https`
# (so a TLS-terminating reverse proxy is enough). Set explicitly to `true`
# to force the flag on (e.g. when terminating TLS in front of Maestro without
# advertising `X-Forwarded-Proto`), or to `false` for local plain-HTTP testing.
# cookie_secure = true
# Whether a successful login deletes all prior sessions for the same user.
# Default `true` — security-first single-session enforcement. Set to `false`
# if you want long-lived multi-client sessions (e.g. desktop + mobile).
# Note: idle session TTL is 24 h, absolute TTL is 30 days regardless of this
# setting. After 5 failed login or recovery attempts in 10 min the account
# is temporarily locked (admin can clear via POST /api/users/{id}/unlock).
# Per-IP rate limit on /api/auth/login and /api/auth/recover is 10 / min.
# kick_other_sessions_on_login = true

[agent]
# AI tool for implement / review / fix steps: "claude" (Claude Code CLI) or "cursor" (Cursor Agent CLI).
provider = "claude"
# Executable for Cursor Agent (default: `agent` from https://cursor.com/install ). Only used when provider = "cursor".
cursor_cli = "agent"
# Cursor Agent --model. "Auto" (default) uses automatic model selection; set a concrete id to pin.
cursor_model = "Auto"
# Timeout per agent session in seconds (applies to all providers).
step_timeout_secs = 1800
# Model override (e.g., "claude-opus-4-6", "claude-sonnet-4-6"). Empty = provider default.
model = ""

[docker]
# build_commands: optional `bash -c` steps during image build (see MAESTRO_BUILD_CONFIG in docker-compose).
# Claude/Cursor skills: use a gitignored ./skills folder at the Maestro repo root; merged on container start (README).
# build_commands = [
#   "apt-get update && apt-get install -y --no-install-recommends some-package",
# ]
build_commands = []

# compose_up_commands: optional; run as maestro after preflight. Skills from ./skills do not require a hook here.
compose_up_commands = []

[editor]
# Application ports to expose when opening VS Code editor from the dashboard
# (e.g. dev server, Storybook). Each port in the container is mapped to a host
# port from the DinD range (9100-9200); mappings are shown on the workflow card.
# ports = [3000, 5173, 6006]

# Number of extra spare ports pre-allocated for automatic detection and forwarding
# of dev servers started inside the editor (e.g. Storybook on port 6006). When a new
# listening port is detected, socat forwards traffic from a spare host port to the
# container port. A toast notification appears on the dashboard with the forwarded URL.
# Set to 0 to disable dynamic port forwarding. Default: 10.
# dynamic_ports = 10

# VS Code color theme
# theme = "One Dark Pro"

# Extensions to pre-install (marketplace IDs)
# extensions = [
#   "esbenp.prettier-vscode",
#   "dbaeumer.vscode-eslint",
#   "eamodio.gitlens",
#   "bradlc.vscode-tailwindcss",
#   "ms-python.python",
# ]

# VS Code settings (any valid setting key = value)
# [editor.settings]
# "editor.fontSize" = 14
# "editor.tabSize" = 2
# "editor.formatOnSave" = true
# "editor.minimap.enabled" = false
# "editor.wordWrap" = "on"
# "terminal.integrated.fontSize" = 13
# "files.autoSave" = "afterDelay"
# "editor.bracketPairColorization.enabled" = true

[terminal]
# Default git editor installed and configured inside every editor container.
# Must be an apt package name (e.g. "nano", "vim", "micro", "helix").
# When set, the package is installed via apt and `git config --global core.editor`
# is updated for the maestro user so git commands (commit, rebase -i, etc.) open
# the chosen editor instead of failing with "unable to start editor 'editor'".
# git_editor = "nano"

# Shell commands run ONCE per editor container lifetime (guarded by a marker file).
# Use for expensive one-time setup: apt packages, tool configuration, etc.
# `/etc/maestro/env` is sourced before each command (API tokens available).
# Mise installs persist in the shared mise volume across container restarts.
# setup_commands = [
#   "mise use -g zellij@latest neovim@latest",
# ]

# Shell commands run EVERY TIME a fresh editor container is created (no once-only guard).
# Use for tools that should be verified/updated on each editor open, e.g. language
# runtimes managed by mise. The shared mise volume caches installs, so only the first
# run downloads; subsequent runs just verify the version is current (fast).
# Note: Rust (cargo, rustc, rustfmt, clippy) is pre-installed in the image — no need
# to add it here.
# startup_commands = [
#   "mise use -g java@21",
#   "mise use -g ruby@3.3",
#   "mise use -g golang@latest",
# ]

[network]
# Additional domains to allow through the egress firewall
# (e.g., private npm registries, internal APIs)
extra_egress_hosts = []
# Example: extra_egress_hosts = ["mycompany.d.codeartifact.amazonaws.com", "internal-api.example.com"]
# When true, skip the egress allowlist and permit all outbound HTTPS (ports 443/8443).
# Use only in trusted environments; `extra_egress_hosts` is ignored when this is enabled.
# allow_all_https = false

# ─── [provisioning] — admin-installed tools (task #48) ──────────────────
#
# Shell commands that install tools into the shared `maestro-tools`
# Docker volume on maestro startup. The volume is bind-mounted READ-ONLY
# into every container Maestro spawns (workers, editors, run-commands)
# at `/opt/maestro-tools/bin`, and the maestro image prepends that path
# to `$PATH` — so anything installed here is on PATH everywhere AND can
# OVERRIDE a baked tool by name (PATH precedence).
#
# Behavior:
#   • SHA-gated: maestro hashes the (canonicalized) `install_commands`
#     list. If the SHA matches the recorded one in
#     `/opt/maestro-tools/.provisioning-sha`, the install pass is SKIPPED.
#     Edit this list → SHA changes → installs run again.
#   • Each command runs as ROOT via `bash -c "$cmd"`. To run as the
#     maestro user (e.g. `mise install`), wrap with `runuser -u maestro --`.
#   • `$MAESTRO_TOOLS_BIN` expands to `/opt/maestro-tools/bin`.
#   • Per-command failures log a WARNING but do NOT abort maestro boot.
#     The SHA is only recorded on FULL success — partial-failure boots
#     retry on the next restart.
#
# Decision guide (when do I use this vs a custom image?):
#   • Single binary CLI tool (kubectl, terraform, a vendor CLI) → here.
#   • Pin a baked tool to a specific version → here (PATH shadowing).
#   • System packages (apt, libraries) → custom Dockerfile `FROM maestro:latest`.
#   • Extra env vars / mounts → docker-compose.override.yml.
# See `docs/extending-maestro.md` for the full reference.
#
# Force re-install (admin escape hatch):
#   docker exec --user root maestro-core-maestro-1 \
#     rm /opt/maestro-tools/.provisioning-sha && docker compose restart maestro
#
# Wipe all customizations and start fresh:
#   docker volume rm maestro-core_maestro-tools && docker compose up -d
[provisioning]
install_commands = [
  # fcli (Figma CLI). Migrated out of the baked image so admins can pin
  # the version or skip the install. amd64 prebuilt; other arches skipped.
  '[ -f "$MAESTRO_TOOLS_BIN/fcli" ] || (ARCH=$(dpkg --print-architecture); [ "$ARCH" = "amd64" ] && curl -fsSL https://github.com/morphet81/figma-cli/releases/download/v0.2.0/fcli-v0.2.0-x86_64-unknown-linux-gnu.tar.gz -o /tmp/fcli.tar.gz && tar -xzf /tmp/fcli.tar.gz -C /tmp && install -m 0755 /tmp/fcli "$MAESTRO_TOOLS_BIN/fcli" && rm -rf /tmp/fcli /tmp/fcli.tar.gz || echo "WARN: fcli skipped on $ARCH")',

  # lokalise2 (Lokalise CLI v2). Single Go binary.
  '[ -f "$MAESTRO_TOOLS_BIN/lokalise2" ] || (ARCH=$(dpkg --print-architecture); case "$ARCH" in amd64) LA=x86_64;; arm64) LA=arm64;; *) LA="";; esac; [ -n "$LA" ] && curl -fSL https://github.com/lokalise/lokalise-cli-2-go/releases/latest/download/lokalise2_linux_${LA}.tar.gz -o /tmp/lk.tar.gz && tar -xzf /tmp/lk.tar.gz -C /tmp && install -m 0755 /tmp/lokalise2 "$MAESTRO_TOOLS_BIN/lokalise2" && rm -rf /tmp/lokalise2 /tmp/lk.tar.gz || echo "WARN: lokalise2 skipped on $ARCH")',

  # figma-cli (npm-based). Installed into the tools volume so workers
  # see it without a global npm prefix override.
  '[ -f "$MAESTRO_TOOLS_BIN/figma-cli" ] || (npm install -g --prefix "$MAESTRO_TOOLS_BIN/.npm" figma-cli && ln -sf "$MAESTRO_TOOLS_BIN/.npm/bin/figma-cli" "$MAESTRO_TOOLS_BIN/figma-cli")',

  # ─── Examples (uncomment to enable) ────────────────────────────────
  #
  # Pin claude to a specific version (overrides the baked @latest):
  #   '[ -f "$MAESTRO_TOOLS_BIN/claude" ] || (npm install -g --prefix "$MAESTRO_TOOLS_BIN/.npm" @anthropic-ai/claude-code@2.1.140 && ln -sf "$MAESTRO_TOOLS_BIN/.npm/bin/claude" "$MAESTRO_TOOLS_BIN/claude")',
  #
  # Install kubectl for workflows that hit a Kubernetes cluster:
  #   '[ -f "$MAESTRO_TOOLS_BIN/kubectl" ] || (curl -fsSLo "$MAESTRO_TOOLS_BIN/kubectl" https://dl.k8s.io/release/v1.31.0/bin/linux/amd64/kubectl && chmod +x "$MAESTRO_TOOLS_BIN/kubectl")',
  #
  # Install AWS CLI v2 (removed from the bake — admin opts in here):
  #   '[ -f "$MAESTRO_TOOLS_BIN/aws" ] || (curl -fsSL "https://awscli.amazonaws.com/awscli-exe-linux-$(uname -m).zip" -o /tmp/aws.zip && unzip -q /tmp/aws.zip -d /tmp && /tmp/aws/install --bin-dir "$MAESTRO_TOOLS_BIN" --install-dir "$MAESTRO_TOOLS_BIN/aws-cli" --update && rm -rf /tmp/aws*)',
]

# --- External database backend (plan-11) ---
#
# By default, Maestro stores users, sessions, credentials, and audit data in a
# local SQLite file at {data_dir}/maestro.db. For multi-instance deployments
# (or operators who want to centralise auth state in their existing DB), the
# [database] block points Maestro at PostgreSQL, MySQL, or MariaDB.
#
# Leaving the section out (or `connection = ""`) keeps the current SQLite
# behaviour — zero-config default.
#
# Restart-only: `PUT /api/config` will not patch this section. Backend changes
# require a process restart, same policy as `web.host` / `web.port`.
#
# [database]
# # Connection URL. Empty / omitted → SQLite at {data_dir}/maestro.db.
# # Supported schemes:
# #   sqlite://path/to/file.db
# #   postgres://user:pw@host:5432/db
# #   postgresql://user:pw@host:5432/db   (alias)
# #   mysql://user:pw@host:3306/db        (covers MariaDB)
# # `GET /api/config` redacts the password component before returning.
# connection = "postgres://maestro:s3cret@db.example:5432/maestro"
#
# # Pool tuning (all optional). Defaults: 10 conns, 30 s acquire timeout,
# # 10 min idle timeout.
# # max_connections = 10
# # acquire_timeout_secs = 30
# # idle_timeout_secs = 600
#
# # When true (default), startup runs a 5 s `SELECT 1` probe against the
# # configured backend and aborts if the database is unreachable. When false,
# # an unreachable backend logs a warning and falls back to local SQLite for
# # the current process (recovery path).
# # fail_fast = true
#
# # When true (default) and a legacy {data_dir}/maestro.db exists AND the
# # remote target has no `system_metadata.import_complete` row, perform a
# # one-shot copy of every user-data table inside a single transaction at
# # startup. Sessions are marked expired post-import so users re-authenticate.
# # Subsequent restarts skip the import (the marker row is the gate). Operators
# # who want to redo the import can `DELETE FROM system_metadata WHERE key =
# # 'import_complete'` against the target — there is no CLI for it on purpose.
# # import_from_sqlite = true

# --- Dev-only knobs (leave commented in production) ---
# When `mock_agent = true`, ClaudeSession::run_prompt and CursorSession::run_prompt
# short-circuit into a scripted mock session — no real `claude` or `agent` process
# is spawned, no API tokens are consumed. Designed for E2E tests and dashboard demos.
# Honors the env var override `MAESTRO_DEV_MOCK_AGENT=1` (env wins over config).
# [dev]
# mock_agent = false
# mock_agent_script_path = "tmp/mock_script.txt"
# mock_agent_line_delay_ms = 75
# mock_agent_total_ms = 5000
