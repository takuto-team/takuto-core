target/
.git/
ui/node_modules/
ui/dist/
.claude/
*.md
!crates/**/*.md
docker-compose.yml
docker-compose.dind.yml
.dockerignore
.env
.env.*
*.log
tests/
design/
# User-specific config files must NOT be baked into the distributed image.
# They are volume-mounted at runtime (see docker-compose.yml).
config.toml
maestro.env
# Exclude user workflow files (local overrides are gitignored; only *.example.toml is tracked).
# NOTE: Podman doesn't support negation (!pattern) reliably, so we exclude specific
# user filenames instead of using a wildcard + exception.
workflows/ticket.toml
workflows/review.toml
workflows/merge_base.toml
