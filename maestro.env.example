# Custom environment variables sourced inside the container
# before authentication and startup.
# Copy to maestro.env and edit.
#
# Example:
# MY_CUSTOM_VAR=value
#
# Cursor Agent (when [agent] provider = "cursor"): avoids interactive login if set
# CURSOR_API_KEY=
#
# License tier: community | cloud | enterprise
# Leave as 'community' for self-hosted open source use.
# Set automatically by Maestro Cloud for hosted users.
MAESTRO_LICENSE_TIER=community

# Config path for entrypoint preflight / hooks (compose sets this by default)
# MAESTRO_CONFIG=/etc/maestro/config.toml
