/target
.DS_Store
.claude/

# Maestro local config (user-specific, not tracked)
/.maestro/config.toml
/.maestro/maestro.env
/.maestro/workflows/*.toml
!/.maestro/workflows/*.example.toml

# Legacy root-level config (if still present)
/config.toml
.env
/maestro.env

# Local issue tracking files
/issues

# Only example workflow files are tracked; copy them to non-example names for local use.
/workflows/*
!/workflows/*.example.toml

# Working files
SECURITY_ASSESSMENT_APPLICATION.md
SECURITY_ASSESSMENT_CONTAINER.md

# React dashboard build output and dependencies
/ui/node_modules/
/ui/dist/

# Distribution repository (nested git repo)
/maestro-releases/

# tmp folder
/tmp

# Custom gitleaks config and reports
.gitleaks.toml
gitleak-report.json

.maestro

.playwright-mcp
