/target
.DS_Store
.claude/

# Takuto local config (user-specific, not tracked)
/.takuto/config.toml
/.takuto/takuto.env
/.takuto/workflows/*.toml
!/.takuto/workflows/*.example.toml

# Legacy root-level config (if still present)
/config.toml
.env
/takuto.env

# Local issue tracking files
/issues

# Only example workflow files are tracked; copy them to non-example names for local use.
/workflows/*
!/workflows/*.example.toml

# Working files
SECURITY_ASSESSMENT_APPLICATION.md
SECURITY_ASSESSMENT_CONTAINER.md

# React dashboard build output and dependencies
/ui/node_modules/
/ui/dist/
/ui/storybook-static/

# Distribution repository (nested git repo)
/takuto-releases/

# tmp folder
/tmp

# DB dumps from `make backup-postgres` / `make backup-mariadb`
/dump/

# Gitleaks scan reports (the .gitleaks.toml config itself is tracked)
gitleak-report.json

.takuto

.playwright-mcp
.playwright-cli
