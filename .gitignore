/target
.DS_Store
.claude/

# Local workflow snapshot / Maestro runtime under configured repo_path (not for version control)
.maestro/

config.toml
.env
maestro.env

# Local issue tracking files
/issues

# Optional per-developer Claude/Cursor skills (see README). Track only `.gitkeep` so `docker compose build` can bind-mount `./skills` without walking the whole repo.
/skills/*
!/skills/.gitkeep

# Only example workflow files are tracked; copy them to non-example names for local use.
/workflows/*
!/workflows/*.example.toml

# Working files
SECURITY_ASSESSMENT_APPLICATION.md
SECURITY_ASSESSMENT_CONTAINER.md

# React dashboard build output and dependencies
/ui/node_modules/
/ui/dist/

# tmp folder
/tmp

# Custom gitleaks config
.gitleaks.toml
